# Copy to .env and edit as needed.  Defaults work out-of-the-box.

# --- Strapi secrets (rotate for any non-demo use) -----------------------------
APP_KEYS=demo-key-1,demo-key-2,demo-key-3,demo-key-4
API_TOKEN_SALT=foodadvisor-api-token-salt-demo
ADMIN_JWT_SECRET=foodadvisor-admin-jwt-secret-demo
TRANSFER_TOKEN_SALT=foodadvisor-transfer-token-salt-demo
JWT_SECRET=foodadvisor-jwt-secret-demo

# --- Strapi runtime ----------------------------------------------------------
NODE_ENV=development

# --- Seed pipeline -----------------------------------------------------------
# Optional. If unset, fetch_unsplash.py falls back to the baseline image bundle
# shipped in seed/data/images/baseline/.
UNSPLASH_ACCESS_KEY=

# Strapi admin credentials created by seed/run_seed.sh on first run.
STRAPI_ADMIN_EMAIL=admin@foodadvisor.demo
STRAPI_ADMIN_PASSWORD=Demo12345!
STRAPI_ADMIN_FIRSTNAME=Demo
STRAPI_ADMIN_LASTNAME=Admin

# --- Readyset ----------------------------------------------------------------
RS_API_KEY=
DISABLE_TELEMETRY=true
