    {
      "id": 102,
      "type": "stat",
      "title": "Cache Hit Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 5
      },
      "targets": [
        {
          "expr": "100 * sum(rate(readyset_shallow_shallow_result_hit{job=\"readyset\"}[$__rate_interval])) / clamp_min(sum(rate(readyset_shallow_shallow_result_hit{job=\"readyset\"}[$__rate_interval])) + sum(rate(readyset_shallow_shallow_result_miss{job=\"readyset\"}[$__rate_interval])), 1)",
          "legendFormat": "",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      }
    },
